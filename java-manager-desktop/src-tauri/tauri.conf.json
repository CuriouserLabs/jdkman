{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JDK Manager",
  "version": "0.1.0",
  "identifier": "com.jdkman.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JDK Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
