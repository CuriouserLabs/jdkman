{
  "name": "jdk-manager",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "prepare:cli-resource": "node ./scripts/prepare-cli-resource.mjs",
    "tauri:build": "npm run prepare:cli-resource && tauri build",
    "tauri:build:debug": "npm run prepare:cli-resource && tauri build --debug",
    "tauri:bundle:macos": "npm run prepare:cli-resource && tauri build --bundles app,dmg",
    "tauri:bundle:linux": "npm run prepare:cli-resource && tauri build --bundles appimage,deb",
    "tauri:bundle:windows": "npm run prepare:cli-resource && tauri build --bundles nsis,msi",
    "tauri:bundle": "npm run prepare:cli-resource && tauri build",
    "tauri:bundle:msi": "npm run prepare:cli-resource && tauri build --bundles msi",
    "tauri:bundle:all": "npm run prepare:cli-resource && tauri build",
    "tauri:icon": "tauri icon",
    "tauri:info": "tauri info",
    "install:deps": "npm install",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
